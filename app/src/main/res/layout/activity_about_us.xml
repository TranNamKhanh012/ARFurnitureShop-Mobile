<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <include
        android:id="@+id/headerAbout"
        layout="@layout/layout_header_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="32dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" /> <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCESSORIES AR"
            android:textColor="#333333"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phiên bản 1.0.0"
                android:textColor="#888888"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chúng tôi tiên phong mang đến trải nghiệm mua sắm phụ kiện thời trang hoàn toàn mới. Với công nghệ thực tế ảo tăng cường (AR), bạn có thể dễ dàng ướm thử kính mắt, mũ, và trang sức ngay trên điện thoại của mình một cách chân thực nhất trước khi quyết định mua hàng."
                android:textColor="#555555"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:gravity="center_horizontal"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>