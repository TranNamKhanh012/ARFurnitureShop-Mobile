<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <include
        android:id="@+id/headerChangePassword"
        layout="@layout/layout_header_title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật khẩu hiện tại"
            android:textColor="#555555"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/edtOldPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_square_edittext"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:hint="Nhập mật khẩu hiện tại"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật khẩu mới"
            android:textColor="#555555"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/edtNewPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_square_edittext"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:hint="Nhập mật khẩu mới"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác nhận mật khẩu mới"
            android:textColor="#555555"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/edtConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_square_edittext"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:hint="Nhập lại mật khẩu mới"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnSavePassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="CẬP NHẬT MẬT KHẨU"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FFB74D"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>